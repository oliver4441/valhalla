{
  "name": "valhalla",
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "data.js",
      "use": "@vercel/static"
    },
    {
      "src": "valhalla-top300.pdf",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
